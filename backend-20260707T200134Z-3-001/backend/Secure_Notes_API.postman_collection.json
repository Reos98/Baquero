          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid-token-here"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "Weak Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
